{
  "name": "huskybc",
  "version": "1.0.0",
  "description": "Unofficial CLI to automate Husky configuration - simplify Git hooks setup with commitlint and lint-staged",
  "devDependencies": {
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "prettier": "3.8.2",
    "eslint": "10.2.0"
  },
  "scripts": {
    "postinstall": "node postinstall.js",
    "preuninstall": "node preuninstall.js"
  },
  "bin": {
    "huskybc": "index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "keywords": [
    "husky",
    "git-hooks",
    "commitlint",
    "lint-staged",
    "cli",
    "automation",
    "git",
    "hooks",
    "configuration",
    "setup",
    "unofficial"
  ],
  "author": {
    "name": "Raul Catalinas",
    "url": "https://github.com/RaulCatalinas"
  },
  "contributors": [
    {
      "name": "Raul Catalinas",
      "url": "https://github.com/RaulCatalinas"
    },
    {
      "name": "Thomas",
      "url": "https://github.com/xxxAlvaDevxxx"
    }
  ],
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RaulCatalinas/HuskyBC.git"
  },
  "bugs": {
    "url": "https://github.com/RaulCatalinas/HuskyBC/issues"
  },
  "homepage": "https://github.com/RaulCatalinas/HuskyBC"
}
