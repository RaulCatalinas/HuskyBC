{
  "languages": {
    "Rust": {
      "format_on_save": "on",
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true,
      },
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true,
      },
    },
  },
}
